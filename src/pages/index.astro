---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { TypeAnimation } from "react-type-animation";
import { TylerParallax } from "@/components/TylerParallax";

import { Player } from "@/components/Player";

const writings = await getCollection("writings");
const featured = writings.filter(({ data }) => data.featured && !data.draft);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-8 pb-6">
      <div class="flex flex-col items-center justify-between gap-8 sm:flex-row">
        <div class="h-min pl-3 text-center sm:border-l-2 sm:text-left">
          <h1 class="inline-block text-4xl font-bold sm:text-5xl">
            Tyler Holewinski
          </h1>

          <div class="mt-2 text-center sm:text-left">
            <TypeAnimation
              client:load
              sequence={SITE.bios
                .toSorted(() => (Math.random() < 0.5 ? -1 : 1))
                .flatMap((bio) => [`Software Engineer & ${bio}`, 5000])}
              repeat={Infinity}
              speed={40}
              deletionSpeed={80}
              preRenderFirstString
            />
          </div>

          {
            SOCIALS.length > 0 && (
              <div class="mt-2 flex flex-col items-center sm:flex-row">
                <Socials />
              </div>
            )
          }
        </div>

        <div>
          <TylerParallax client:load />
          <Player client:load />
        </div>
      </div>

      {
        !SITE.shame && featured.length > 0 && (
          <>
            <section id="featured" class="pt-12 pb-6">
              <h2 class="text-2xl font-semibold tracking-wide">Writing</h2>
              <ul>
                {featured.map((data) => (
                  <Card variant="h3" {...data} />
                ))}
              </ul>
            </section>
          </>
        )
      }
    </section>
    <Footer />
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const indexLayout = (
        document.querySelector("#main-content") as HTMLElement
      )?.dataset?.layout;
      if (indexLayout) {
        sessionStorage.setItem("backUrl", "/");
      }
    });
  </script>
</Layout>
